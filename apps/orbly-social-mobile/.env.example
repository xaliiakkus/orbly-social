# ─── Geliştirme (bilgisayarda API çalışıyorsa) ───
# localhost fiziksel cihazda Expo packager IP'sine çevrilir.
# Sorun olursa LAN IP: http://192.168.x.x:4000
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_WEB_URL=http://localhost:3000

# ─── Production (fiziksel cihaz / TestFlight / APK — ZORUNLU) ───
# apps/orbly-social-mobile/.env dosyası oluşturup şunları kullanın:
# EXPO_PUBLIC_API_URL=https://api.orbly.social
# EXPO_PUBLIC_WEB_URL=https://orbly.social
# Sonra: yarn --cwd apps/orbly-social-mobile start -c  (cache temiz)

# Native LiveKit: Expo Go çalışmaz — development build:
#   yarn --cwd apps/orbly-social-mobile exec expo prebuild
#   yarn --cwd apps/orbly-social-mobile android

# Google OAuth
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
