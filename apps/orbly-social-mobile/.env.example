# Geliştirmede localhost otomatik olarak Expo packager IP'sine çevrilir (fiziksel cihaz).
# Sorun olursa doğrudan LAN IP kullan: http://192.168.x.x:4000
EXPO_PUBLIC_API_URL=http://localhost:4000

# Web fallback (Expo Go) ve paylaşım linkleri
EXPO_PUBLIC_WEB_URL=http://localhost:3000

# Native LiveKit: Expo Go çalışmaz — development build gerekir:
#   yarn --cwd apps/orbly-social-mobile exec expo prebuild
#   yarn --cwd apps/orbly-social-mobile android   # veya ios

# Google OAuth — iOS için EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID zorunlu (Google Cloud iOS client)
# Android: EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID veya web client ID
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
