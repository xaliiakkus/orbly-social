# fly.toml [env] ile aynı anahtarlar — güncelleme için referans.
# Hassas değerleri repoya koymamak için: fly secrets import < .env.fly

PORT=8080
NODE_ENV=production
API_PUBLIC_URL=https://api.orbly.social

MONGO_URI=mongodb+srv://USER:PASS%26@cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGO_DB_NAME=orbly

JWT_SECRET=uzun-rastgele-production-secret
JWT_ACCESS_EXPIRES_MIN=15
JWT_REFRESH_EXPIRES_DAYS=7
CORS_ORIGIN=https://orbly.social,http://localhost:3000

REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379
REDIS_ENABLED=true

IDRIVE_ENDPOINT=https://s3.us-west-2.idrivee2.com
IDRIVE_REGION=us-west-2
IDRIVE_ACCESS_KEY_ID=
IDRIVE_SECRET_ACCESS_KEY=
IDRIVE_BUCKET=orbly-bucket
IDRIVE_PUBLIC_URL=https://s3.us-west-2.idrivee2.com/orbly-bucket

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

MEDIA_LOCAL_FALLBACK=false

GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
TENOR_API_KEY=

LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
