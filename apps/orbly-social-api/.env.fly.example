# Fly secrets import için — lokal .env dosyasını AYNEN import ETMEYİN (PORT=4000 kırar).
# Kopyala: cp .env.fly.example .env.fly → değerleri doldur → fly secrets import < .env.fly

MONGO_URI=mongodb+srv://USER:PASS%26@cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGO_DB_NAME=orbly
JWT_SECRET=uzun-rastgele-production-secret
CORS_ORIGIN=https://orbly.social,http://localhost:3000
API_PUBLIC_URL=https://api.orbly.social
REDIS_ENABLED=true
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379

CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
MEDIA_LOCAL_FALLBACK=false
