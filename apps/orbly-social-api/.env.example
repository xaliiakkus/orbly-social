# Copy to .env
NODE_ENV=development
PORT=4000
# MONGO_URI or MONGODB_URI; encode special chars in password (e.g. & → %26)
MONGO_URI=mongodb+srv://xaliakkus_db_user:34Patron47%26@cluster0.okyk1jy.mongodb.net/?appName=Cluster0
MONGO_DB_NAME=orbly
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_ACCESS_EXPIRES_MIN=15
JWT_REFRESH_EXPIRES_DAYS=7
# Virgülle ayır: web + mobil + prod frontend origin’leri (scheme + host, path yok)
CORS_ORIGIN=http://localhost:3000,http://localhost:8081,https://orbly.social,https://www.orbly.social

REDIS_URL=redis://127.0.0.1:6379
REDIS_ENABLED=true

# Cloudinary — görseller (presign → CDN)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# iDrive e2 — videolar + görsel yedek (S3 API)
IDRIVE_ENDPOINT=https://s3.us-west-2.idrivee2.com
IDRIVE_REGION=us-west-2
IDRIVE_ACCESS_KEY_ID=
IDRIVE_SECRET_ACCESS_KEY=
IDRIVE_BUCKET=orbly-media
IDRIVE_PUBLIC_URL=https://s3.us-west-2.idrivee2.com/orbly-media

# Cloudflare R2 (IDRIVE yoksa alternatif S3)
# R2_ENDPOINT=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
MEDIA_LOCAL_FALLBACK=true
API_PUBLIC_URL=http://localhost:4000

# OAuth
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# Tenor GIF search (https://developers.google.com/tenor)
TENOR_API_KEY=

