{
  "name": "orbly-social-api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 4000",
    "start": "python -m uvicorn app.main:app --host 0.0.0.0 --port 4000",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "seed": "python seed.py"
  }
}
