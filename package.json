{
  "name": "orbly-social",
  "private": true,
  "workspaces": [
    "apps/orbly-social-api",
    "apps/orbly-social-mobile",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:api": "yarn workspace @orbly/api dev",
    "dev:web": "yarn --cwd apps/orbly-social-web dev",
    "dev:mobile": "yarn workspace mobile dev",
    "db:seed": "cd apps/orbly-social-api && python seed.py",
    "generate:icons": "yarn workspace mobile generate:icons"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "yarn@4.14.1",
  "engines": {
    "node": ">=20"
  }
}
