{
  "name": "orbly-social",
  "private": true,
  "scripts": {
    "dev:api": "cd apps/orbly-social-api && python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 4000",
    "dev:web": "yarn --cwd apps/orbly-social-web dev",
    "dev:mobile": "yarn --cwd apps/orbly-social-mobile dev",
    "db:seed": "cd apps/orbly-social-api && python seed.py",
    "generate:icons": "yarn --cwd apps/orbly-social-mobile generate:icons"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "yarn@4.14.1",
  "engines": {
    "node": ">=20"
  }
}
